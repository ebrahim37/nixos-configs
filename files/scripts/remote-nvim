#!/usr/bin/env bash

hosts=(
  "vps1c|100.64.0.1"
  "pc-qemu|100.64.0.21"
  "mba-utm|100.64.0.22"
)

echo "Select a host:"
for i in "${!hosts[@]}"; do
  IFS='|' read -r hostname tailnet_ip <<< "${hosts[$i]}"
  printf '%d: %s (%s)\n' "$((i + 1))" "$hostname" "$tailnet_ip"
done

while true; do
  read -r -n 1 selection
  echo

  if [[ "$selection" =~ ^[1-${#hosts[@]}]$ ]]; then
    break
  fi

  echo "Invalid selection."
done

IFS='|' read -r hostname tailnet_ip <<< "${hosts[$((selection - 1))]}"

ssh "$hostname" \
  "nohup ~/scripts/nvi --headless --listen '$tailnet_ip:9321' \
  > /tmp/nvim-headless.log 2>&1 < /dev/null &"

sleep 1

nvi --server "$tailnet_ip:9321" --remote-ui
